generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

// ─── User & Auth ──────────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  role      Role      @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── Game Data ────────────────────────────────────────────────

model Game {
  id             String   @id @default(cuid())
  number         Int?
  name           String
  cover          String?
  date           String?
  platform       String?

  loveRank       String?
  difficultyRank String?

  year           Int?
  love           Float?
  difficulty     Float?
  pride          Float?
  achievement    Float?
  list           Float?
  total          Float?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  syncLogs       SyncLog[]

  @@unique([name, platform])  // ← composite unique key
}

// ─── Sync Tracking ────────────────────────────────────────────

model SyncLog {
  id              String   @id @default(cuid())
  ranAt           DateTime @default(now())
  recordsProcessed Int
  recordsSkipped  Int      @default(0)
  success         Boolean
  error           String?           // null if successful
  gameId          String?
  game            Game?    @relation(fields: [gameId], references: [id])
}